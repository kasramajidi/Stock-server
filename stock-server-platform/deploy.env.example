# نمونهٔ متغیرها برای اجرا روی VPS (همین سروری که PostgreSQL نصب است)
#
# روی سرور، بعد از کپی کردن پروژه:
#   cp deploy.env.example .env
#   nano .env
# مقدار YOUR_DB_PASSWORD را با رمز واقعی کاربر appuser جایگزین کن.
# سپس: npm ci && npx prisma generate && npx prisma db push && npm run build && pm2 ...

DATABASE_URL="postgresql://appuser:YOUR_DB_PASSWORD@localhost:5432/stockdb?schema=public"

JWT_SECRET="حداقل-۳۲-کاراکتر-تصادفی-برای-توکن-ورود"

NEXT_PUBLIC_SITE_URL="https://stockserver.ir"
SITE_URL="https://stockserver.ir"

# ایمیل (اختیاری — در صورت نیاز از .env لوکال کپی کن)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=
