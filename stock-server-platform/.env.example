# PostgreSQL - Prisma
# این فایل را کپی کن به نام `.env` و مقادیر را پر کن (فایل `.env` commit نشود).

# برای deploy روی VPS از فایل `deploy.env.example` در همین پوشه استفاده کن (آنجا DATABASE_URL با localhost است).

# --- روی VPS (PostgreSQL روی همان سرور، کاربر/دیتابیس را خودت ساختی) ---
# رمز را داخل کوتیشن تکی بگذار؛ کاراکتر خاص داشت URL-encode کن.
DATABASE_URL="postgresql://appuser:YOUR_DB_PASSWORD@localhost:5432/stockdb?schema=public"

NEXT_PUBLIC_SITE_URL="https://stockserver.ir"
SITE_URL="https://stockserver.ir"

# --- لوکال یا هاست ابری (مثال) ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT (حداقل ۳۲ کاراکتر، برای توکن ورود)
JWT_SECRET="your-secret-at-least-32-characters-long"

# CORS - دامنه‌های مجاز (با کاما جدا کن؛ * = همه)
# CORS_ORIGINS="http://localhost:3000,https://yoursite.com"

# ایمیل (برای ارسال به شرکت و پاسخ به کاربر)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your@gmail.com
# MAIL_PASS=app-password
# MAIL_FROM=noreply@yoursite.com
